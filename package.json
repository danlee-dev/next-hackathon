{
  "name": "trustpitch-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "frontend:dev": "pnpm --dir frontend dev",
    "frontend:build": "pnpm --dir frontend build",
    "frontend:test": "pnpm --dir frontend test",
    "frontend:lint": "pnpm --dir frontend lint",
    "frontend:typecheck": "pnpm --dir frontend typecheck"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx,js,jsx,json}": [
      "pnpm --dir frontend exec biome check --write --no-errors-on-unmatched"
    ]
  },
  "packageManager": "pnpm@10.11.0"
}
